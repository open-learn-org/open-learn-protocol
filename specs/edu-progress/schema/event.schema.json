{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-learn-protocol.org/specs/edu-progress/v1/event.schema.json",
  "title": "EduProgress event envelope",
  "type": "object",
  "required": ["event_id", "type", "occurred_at", "child_ref", "app_ref", "data"],
  "additionalProperties": false,
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "description": "ULID or UUIDv7 generated by the reporter."
    },
    "type": {
      "type": "string",
      "enum": [
        "session.started",
        "session.ended",
        "activity.started",
        "activity.completed",
        "skill.progress",
        "struggle.signal"
      ]
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "received_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "child_ref": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "iss": { "type": "string", "format": "uri" },
        "sub": { "type": "string", "minLength": 1, "maxLength": 128 },
        "email": { "type": "string", "format": "email" },
        "child_id": { "type": "string", "minLength": 1, "maxLength": 128 }
      },
      "dependentRequired": {
        "iss": ["sub"],
        "sub": ["iss"]
      }
    },
    "app_ref": {
      "type": "object",
      "required": ["app_id"],
      "additionalProperties": false,
      "properties": {
        "app_id": { "type": "string", "minLength": 1, "maxLength": 64 },
        "version": { "type": "string", "maxLength": 32 }
      }
    },
    "session_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "data": {
      "type": "object"
    }
  }
}
