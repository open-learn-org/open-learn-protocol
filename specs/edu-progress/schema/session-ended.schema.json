{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-learn-protocol.org/specs/edu-progress/v1/session-ended.schema.json",
  "title": "session.ended data",
  "type": "object",
  "required": ["ended_at", "active_ms", "reason"],
  "additionalProperties": false,
  "properties": {
    "ended_at": { "type": "string", "format": "date-time" },
    "active_ms": {
      "type": "integer",
      "minimum": 0,
      "description": "Active time during the session, in milliseconds. Excludes idle time if the reporter tracks it."
    },
    "reason": {
      "type": "string",
      "enum": ["closed", "timeout", "switched", "unknown"]
    }
  }
}
