{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-learn-protocol.org/specs/edu-progress/v1/skill-progress.schema.json",
  "title": "skill.progress data",
  "type": "object",
  "required": ["skill_id", "level"],
  "additionalProperties": false,
  "properties": {
    "skill_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Opaque dotted string. App-defined; not standardized in v1."
    },
    "level": { "type": "number", "minimum": 0, "maximum": 1 },
    "delta": { "type": "number", "minimum": -1, "maximum": 1 },
    "evidence": {
      "type": "array",
      "maxItems": 16,
      "items": { "type": "string", "maxLength": 128 }
    }
  }
}
